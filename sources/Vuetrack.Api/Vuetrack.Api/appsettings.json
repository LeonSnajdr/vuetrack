{
  "Brand": "<FROM_ENV>",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.DataProtection": "Error",
        "Microsoft.Extensions.Diagnostics.HealthChecks.DefaultHealthCheckService": "Fatal",
        "Microsoft": "Warning",
        "System": "Warning",
        "HealthChecks.UI": "Fatal",
        "Serilog.AspNetCore": "Warning",
        "Samhammer.Options": "Warning",
        "Samhammer.DependencyInjection": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "ZiggyCreatures.Caching.Fusion.FusionCache": "Warning"
      }
    }
  },
  "LoggingOptions": {
    "LogFile": "vuetrack.log",
    "LogFolder": "/app/logs/",
    "EnableElasticLogging": true,
    "EnableFileLogging": true,
    "EnableConsoleLogging": false
  },
  "LogstashOptions": {
    "Url": "",
    "ElasticIndex": "vuetrack-{environment}",
    "UserName": "",
    "Password": ""
  },
  "MongoDbOptions": {
    "DatabaseCredentials": [
      {
        "DatabaseHost": "",
        "UserName": "",
        "Password": "",
        "DatabaseName": "vuetrack-{environment}-{brand}{-branch}"
      }
    ]
  },
  "CorsPolicyOptions": {
    "DomainUrls": []
  },
  "AllowedHosts": "*",
  "SuggestionEngineOptions": {
    "MergeGap": "00:15:00",
    "RoundTo": "00:05:00",
    "MinimumBlock": "00:05:00",
    "DefaultPointDuration": "00:15:00",
    "CorrelationMetadataKey": "correlationId"
  },
  "JiraOptions": {
    "IdentityBaseUrl": "https://auth.atlassian.com",
    "ApiBaseUrl": "https://api.atlassian.com",
    "ClientId": "",
    "ClientSecret": "",
    "Scopes": "read:jira-work read:jira-user offline_access",
    "PageSize": 50,
    "MaxPages": 20
  },
  "TimetrackingOptions": {
    "ApiBaseUrl": "",
    "AuthorizeEndpoint": "https://auth-test.cloud.samhammer.de/auth/realms/timetracking-dev/protocol/openid-connect/auth",
    "TokenEndpoint": "https://auth-test.cloud.samhammer.de/auth/realms/timetracking-dev/protocol/openid-connect/token",
    "ClientId": "",
    "ClientSecret": "",
    "Scopes": "openid profile offline_access"
  },
  "ApiAuthOptions": {
    "AccessTokenUrl": "",
    "Issuer": "",
    "ClientId": "",
    "ClientSecret": "",
    "Realm": ""
  },
  "SwaggerAuthOptions": {
    "AccessTokenUrl": "",
    "AuthUrl": "",
    "ClientId": ""
  },
  "AppAuthOptions": {
    "AuthUrl": "",
    "Realm": "",
    "AppClientId": "",
    "ApiClientId": ""
  }
}
