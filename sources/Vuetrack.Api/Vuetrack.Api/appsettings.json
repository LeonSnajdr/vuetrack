{
  "Brand": "<FROM_ENV>",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.DataProtection": "Error",
        "Microsoft.Extensions.Diagnostics.HealthChecks.DefaultHealthCheckService": "Fatal",
        "Microsoft": "Warning",
        "System": "Warning",
        "HealthChecks.UI": "Fatal",
        "Serilog.AspNetCore": "Warning",
        "Samhammer.Options": "Warning",
        "Samhammer.DependencyInjection": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "ZiggyCreatures.Caching.Fusion.FusionCache": "Warning"
      }
    }
  },
  "LoggingOptions": {
    "LogFile": "vuetrack.log",
    "LogFolder": "/app/logs/",
    "EnableElasticLogging": true,
    "EnableFileLogging": true,
    "EnableConsoleLogging": false
  },
  "LogstashOptions": {
    "Url": "",
    "ElasticIndex": "vuetrack-{environment}",
    "UserName": "",
    "Password": ""
  },
  "MongoDbOptions": {
    "DatabaseCredentials": [
      {
        "DatabaseHost": "",
        "UserName": "",
        "Password": "",
        "DatabaseName": "vuetrack-{environment}-{brand}{-branch}"
      }
    ]
  },
  "CorsPolicyOptions": {
    "DomainUrls": []
  },
  "AllowedHosts": "*",
  "ApiAuthOptions": {
    "AccessTokenUrl": "",
    "Issuer": "",
    "ClientId": "",
    "ClientSecret": "",
    "Realm": ""
  },
  "SwaggerAuthOptions": {
    "AccessTokenUrl": "",
    "AuthUrl": "",
    "ClientId": ""
  },
  "AppAuthOptions": {
    "AuthUrl": "",
    "Realm": "",
    "AppClientId": "",
    "ApiClientId": ""
  }
}
