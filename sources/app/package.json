    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@cspell/dict-de-de": "^4.1.2",
